# Jupyter / notebooks
.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*~

# Large data dirs: ignored
data/cfsds/
data/fields/
data/metrics/
data/renders/
data/temp/
data/manifests/

# Generated results dirs: ignored
results/analysis_studies/
results/operational_studies/

# Notes working artifacts not needed in frozen repo
notes/presentations/
notes/images/

# Generated manifests are ignored by default.
# Curated thesis/release manifests should be copied into docs or another tracked fixture path if needed.
# - data/figures/
# - results/figures/

# Environments / secrets
.env
.env.*
!.env.example
!.env.local.example

# Python packaging
*.egg-info/
.eggs/
build/
dist/

# Generic top-level dirs only
/node_modules/
/.next/
/out/
/dist/
/build/
/notes/
/results/

# Source utilities are tracked by default.
# Scratch/ad hoc source scripts are kept here and ignored.
src/do_not_track/
